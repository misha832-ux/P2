generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id         String @id @default(auto()) @db.ObjectId @map("_id")
  userId     String
  name       String?
  age        Int
  gender     String
  profession String
  createdAt  DateTime @default(now())
}

model AiEntry {
  id        String @id @default(auto()) @db.ObjectId @map("_id")
  text      String
  createdAt DateTime @default(now())
}

model ManualEntry {
  id        String @id @default(auto()) @db.ObjectId @map("_id")
  text      String
  createdAt DateTime @default(now())
}